programa {
  funcao inicio() {
    //Definição

    inteiro numero1, numero2, multiplicao

    //Leitura
    
    escreva("Digite o primeiro numero: ")
    leia(numero1)

    escreva("Digite o segundo numero: ")
    leia(numero2)

    //Calculo

    multiplicao = numero1 * numero2

    //Resultado
    escreva("-----------Resultado-----------", "\n")
    escreva("O resultado da sua multiplicação é: ", multiplicao)
    
  }
}
