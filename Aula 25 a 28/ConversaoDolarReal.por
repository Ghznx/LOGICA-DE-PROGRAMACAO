programa {
  funcao inicio() {
    //Definição
    real cotdolar , quantidadeDolar , conversao
    //Apresentação

    escreva("Apresente o valor do $ Atual: ")
    leia(cotdolar)

    escreva("Sua quantidade de doláres disponíveis: ")
    leia(quantidadeDolar)
    //Conversão
    conversao = quantidadeDolar*cotdolar
    //Finalização
    escreva("Seus doláres convertidos em real: ", conversao)
    
  }
}
