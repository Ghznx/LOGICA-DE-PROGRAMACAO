programa {
  funcao inicio() {
    //Definição
    real mamaoComAcucar = 4 , quantidadeMamao , prestacao
    //Ação
    escreva("Quantidade comprada: ")
    leia(quantidadeMamao)
    //Calculo
    prestacao = (quantidadeMamao*mamaoComAcucar)/5
    //Exibição de valores
    escreva("O valor da sua compra é ", prestacao , " em 5 prestações")

    
  }
}
