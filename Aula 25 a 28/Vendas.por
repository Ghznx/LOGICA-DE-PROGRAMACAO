programa {
  funcao inicio() {
    //Definição
    real custoDoProduto , custoDoProdutofinal 
    //Ação
    escreva("Digite o preço de custo do produto: ")
    leia(custoDoProduto)
    //Calculo
    custoDoProdutofinal = custoDoProduto*1.5
    //Exibição
    escreva("O valor de venda é: ", custoDoProdutofinal)
  }
}
