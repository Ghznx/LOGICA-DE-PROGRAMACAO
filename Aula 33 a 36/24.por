programa {
  funcao inicio() {
    //Definição
    inteiro a , b , c
    //Informação
    escreva("Informe o primeiro valor: ")
    leia(a)

    escreva("Informe o segundo valor: ")
    leia(b)

    //Resultado
    se(a==b)
     {
      c=a+b escreva("a + b = ", c)
     }
    senao
     {
      c=a*b
      escreva("a * b = ", c)
     }
    
  }
}
