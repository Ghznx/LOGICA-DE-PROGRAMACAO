programa {
  funcao inicio() {
    //Definição
    inteiro numero
    //Informação
    escreva("Informe um numero: ")
    leia(numero)
    //Resultado
    se(numero>0)
    {
      escreva("Numero é positivo")
    }
    senao se(numero==0)
    {
      escreva("Numero é o zero")
    }
    senao
    {
      escreva("Numero negativo")
    }
    
    
  }
}
