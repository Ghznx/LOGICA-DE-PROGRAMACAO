programa
{
    funcao inicio()
    {
        inteiro numero

        escreva("Informe um número: ") //Texto adicionado para identificação
        leia(numero)

        //se (numero < 0)
        se (numero > 0)
        {
            escreva("Numero positivo")
        }
        senao //Adicionado um complemento
        {
           escreva("Numero negativo")
        }
    }
}