programa
{
    funcao inicio()
    {
        inteiro senha

        escreva("Escreva sua senha: ") //Texto adicionado para identificação
        leia(senha)

        //se (senha != 1234)
        se (senha == 1234)
        {
            escreva("Acesso liberado")
        }
        senao
        {
            escreva("Senha incorreta")
        }
    }
}