programa
{
    funcao inicio()
    {
        inteiro idade

        escreva("Informe sua idade: ") //Texto adicionado para identificação
        leia(idade)

        //se (idade >= 12 ou idade <= 17)
        se (idade >= 12 e idade <= 17)
        {
            escreva("Adolescente")
        }
        senao
        {
            escreva("Não é adolescente")
        }
    }
}