programa {
  funcao inicio() {
    inteiro numero[5] = {" ", " ", " ", 5, 10 }

    escreva("Informe um valor para a primeira posição: ")
    leia(numero[0])
    escreva("Informe um valor para a segunda posição: ")
    leia(numero[1])
    escreva("Informe um valor para a terceira posição: ")
    leia(numero[2])

    escreva(numero[0], "\n")
    escreva(numero[1], "\n")
    escreva(numero[2], "\n")
    escreva(numero[3], "\n")
    escreva(numero[4])
  }
}
