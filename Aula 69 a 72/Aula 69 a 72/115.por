programa {
  funcao inicio() {
    inteiro numero[4] = {4 , 5 , 8 , 9}
    inteiro soma , multiplicacao , diferenca

    soma = numero[0] + numero[3]

    multiplicacao = numero[1] * numero[2]

    diferenca = numero[2] - numero[0]

    escreva(soma, "\n")
    escreva(multiplicacao, "\n")
    escreva(diferenca)
  }
}
